cryptos 소스코드 넘기실분은 넘기세요
<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<title>Cryptos v3.6</title>

<style>
body{
background:#0d1117;
color:#c9d1d9;
font-family:Arial;
text-align:center;
padding:40px;
}

.box{
max-width:700px;
margin:auto;
background:#161b22;
padding:30px;
border-radius:15px;
}

textarea{
width:100%;
height:120px;
background:#010409;
color:#58a6ff;
font-size:18px;
padding:10px;
margin:10px;
}

button{
padding:8px 12px;
margin:4px;
cursor:pointer;
}

.active{
background:#58a6ff;
}

</style>

</head>

<body>

<div class="box">

<h1>🔮 CRYPTOS v3.6</h1>

<textarea id="input"
placeholder="영어 입력"></textarea>


<div>

<button onclick="addState('✍︎')">
분노
</button>

<button onclick="addState('✏︎')">
해탈
</button>

<button onclick="addState('📫︎')">
여유
</button>

<button onclick="addState('⌛︎')">
피로
</button>

<button onclick="addState('✁︎')">
방전
</button>

<button onclick="addState('😜')">
위트
</button>

<button onclick="addState('☺︎')">
평온
</button>

<button onclick="addState('❑︎')">
무표정
</button>

<button onclick="addState('☠︎')">
위급
</button>

</div>


<br>

<button onclick="mode='symbol';run()">
기호
</button>

<button onclick="mode='sound';run()">
발음
</button>


<textarea id="output" readonly></textarea>


</div>



<script>


let mode="symbol";

let states=[];



const cryptoDict={

a:'♋︎',
b:'♌︎',
c:'♍︎',
d:'♎︎',
e:'♏︎',
f:'♐︎',
g:'♑︎',
h:'🙧',
i:'⬧︎',
j:'🙨',
k:'🙩',
l:'●︎',
m:'❍︎',
n:'⏹︎',
o:'□︎',
p:'◻︎',
q:'❑︎',
r:'❒︎',
s:'⬧︎',
t:'⧫︎',
u:'◆︎',
v:'❖︎',
w:'⬪︎',
x:'⌧︎',
y:'⍳︎',
z:'⪿'

};



const pronunciation={

a:'아',
b:'브',
c:'크',
d:'드',
e:'오',
f:'프',
g:'그',
h:'흐',
i:'이',
j:'즈',
k:'크',
l:'엘',
m:'엠',
n:'엔',
o:'오',
p:'프',
q:'큐',
r:'르',
s:'스',
t:'트',
u:'우',
v:'브',
w:'우',
x:'크스',
y:'이',
z:'즈'

};



const numDict={

'0':'X',
'1':'и',
'2':'л',
'3':'т',
'4':'Ж',
'5':'С',
'6':'б',
'7':'о',
'8':'Я',
'9':'е'

};



function encryptNumber(n){

n=parseInt(n);

n*=8;


while(n>0 && n%4===0){

n=Math.floor(n/4);

}


n=n*3+5;


let result="";


for(let x of String(n)){

result+=numDict[x];

}


return result;

}




function addState(s){

if(states.includes(s)){

states.splice(states.indexOf(s),1);

}else{

states.push(s);

}


run();

}




function convert(text){


let result="";

let sound="";


for(let i=0;i<text.length;i++){

let c=text[i];


// 문장부호 유지

if(/[.,!?]/.test(c)){

result+=c;

sound+=c;

continue;

}


// 숫자

if(/[0-9]/.test(c)){


if(i===0 || text[i-1]==" ")

result+="📄︎";


result+=encryptNumber(c);

sound+=c;

}


// 문자

else if(cryptoDict[c]){


if(i===0 || text[i-1]==" ")

result+="📄︎";


result+=cryptoDict[c];

sound+=pronunciation[c];

}


// 공백

else{


result+=c;

sound+=c;

}


}



return mode==="symbol"
? result
: sound;


}




function run(){

let text=document
.getElementById("input")
.value
.toLowerCase();



let result=convert(text);


// 상황명사

if(states.length){

result+=" "+states.join("+");

}


// 출력

document
.getElementById("output")
.value=result;


}



document
.getElementById("input")
.oninput=run;



</script>

</body>
</html>
